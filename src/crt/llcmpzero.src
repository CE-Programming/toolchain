	.assume	adl=1

	.section	.text

	.global	__llequzero
	.type	__llequzero, @function

	.global	__llcmpzero
	.type	__llcmpzero, @function

__llequzero:
	; Zero flag = (BC:UDE:UHL == 0)
__llcmpzero:
	; Zero flag = (BC:UDE:UHL == 0)
	; Sign flag = (BC:UDE:UHL < 0)
	inc	b
	dec	b
	ret	nz
	inc.s	bc
	dec	c
	jr	nz, .L.p_nz
	or	a, a
	sbc	hl, bc
	jr	nz, .L.p_nz
	sbc	hl, de
	ret	z
	add	hl, de
.L.p_nz:
	inc	b
	ld	b, 0
	ret
