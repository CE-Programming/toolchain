	.assume	adl=1

	.section	.text
	.global	__fpupop1
	.type	__fpupop1, @function

__fpupop1:
	push	hl
	scf
	sbc	hl, hl
	add	hl, sp
	push	bc
	rlc	(hl)		;move high-bit to low-bit
	scf
	rr	(hl)		;carry = exponent low-bit, high-bit = 1
	pop	bc		;restore modified mantissa
	adc	a, a		;compute exponent, carry = sign
	ld	d, 0
	jr	nz, nzero	;skip if exponent non-zero

	ld	bc, 0		;clear mantissa
	or	a, a		;clear carry
nzero:
	rl	d		;set 1 if negative operand
	or	a, a		;set Z/NZ
	pop	hl
	ret
