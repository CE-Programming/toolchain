	.assume	adl=1

	.section	.text

	.global	__drem
	.type	__drem, @function

; long double __drem_c(long double const *__restrict y, long double x)
__drem:
	push	iy
	push	af

	push	bc
	push	de
	push	hl
	ld	hl, 18
	add	hl, sp
	push	hl
	call	___drem_c
	pop	af
	pop	af
	pop	af
	pop	af

	pop	af
	pop	iy
	ret

	.extern	___drem_c
