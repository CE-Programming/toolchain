	.assume	adl=1

	.section	.text
	.global	__llshrs_1
	.type	__llshrs_1, @function

__llshrs_1:
	; Input:
	; - BC:UDE:UHL
	; Output:
	; - BC:UDE:UHL >>= 1 (signed)
	; - Carry = shifted-out bit
	; Cost: 28 bytes | 29F + 11R + 8W + 3
	push	hl
	scf
	sbc	hl, hl
	add	hl, sp
	push	de
	sra	b
	rr	c
	rr	(hl)
	pop	de
	inc	hl
	inc	hl
	inc	hl
	rr	d
	rr	e
	rr	(hl)
	pop	hl
	rr	h
	rr	l
	ret
