	.assume	adl=1

	.section	.text

	.global	__sshrs
	.type	__sshrs, @function
	.global	__sshrs_nz
	.type	__sshrs_nz, @function

.ifdef PREFER_OS_CRT

	.set	__sshrs, 0x000248
	.set	__sshrs_nz, __sshrs

.else

__sshrs:
; Suboptimal for large shift amounts
; CC: if C!=0: C*(7*r(PC)+1)+7*r(PC)+(ADL?6*r(SPL)+3*w(SPL):4*r(SPS)+2*w(SPS))+1
;     if C==0: 4*r(PC)+(ADL?3*r(SPL):2*r(SPS))+2
	inc	c
	dec	c
	ret	z
__sshrs_nz:
	push	bc
	ld	b, c
.L.loop:
	sra	h
	rr	l
	djnz	.L.loop
	pop	bc
	ret

.endif
