	.assume	adl=1

	.section	.text

	.global	__dmul
	.type	__dmul, @function

; long double __dmul_c(long double const *__restrict y, long double x)
__dmul:
	push	iy
	push	af

	push	bc
	push	de
	push	hl
	ld	hl, 18
	add	hl, sp
	push	hl
	call	___dmul_c
	pop	af
	pop	af
	pop	af
	pop	af

	pop	af
	pop	iy
	ret

	.extern	___dmul_c
