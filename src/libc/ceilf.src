	.assume	adl=1

	.section	.text
	.global	_ceilf
	.type	_ceilf, @function
	.global	_ceil
	.type	_ceil, @function

.ifdef PREFER_OS_LIBC

	.set	_ceilf, 0x022114
	.set	_ceil, _ceilf

.else

_ceil:
_ceilf:
	pop	de
	pop	bc
	ex	(sp), hl
	ld	a, l
	push	bc
	push	de
	call	__fpceil
	push	bc
	pop	hl
	ld	e, a
	ret

	.extern	__fpceil

.endif
