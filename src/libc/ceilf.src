	.assume	adl=1

	.section	.text
	.global	_ceil
	.type	_ceil, @function
	.global	_ceilf
	.type	_ceilf, @function

.ifdef PREFER_OS_LIBC

	.set	_ceilf, 0x022114
	.set	_ceil, _ceilf

.else

_ceil:
_ceilf:
	ld	hl, 6
	add	hl, sp
	ld	a, (hl)
	dec	hl
	dec	hl
	dec	hl
	ld	bc, (hl)
	call	__fneg
	ld	l, a
	push	hl
	push	bc
	call	_floor
	pop	bc
	ex	(sp), hl
	pop	bc
	ld	a, e
	call	__fneg
	ld	e, a
	push	bc
	pop	hl
	ret

	.extern	__fneg
	.extern	_floor

.endif
