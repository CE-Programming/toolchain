	.assume	adl=1

	.section	.text
	.global	_toupper
	.type	_toupper, @function

_toupper:
	pop	de
	ex	(sp), hl
	push	de
; REQUIRE	require	_toupper.internal

; REQUIRE	.section	.text
	.global	_toupper.internal
	.type	_toupper.internal, @function
_toupper.internal:
	; ASM interface: input/output char in L, destroys AF
	ld	a, l
	sub	a, 'a'
	cp	a, 1+'z'-'a'
	ret	nc

	res	5, l
	ret
