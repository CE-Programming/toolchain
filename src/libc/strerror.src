	.local	__strerror_no_error
__strerror_no_error:
	db	"no error", 0


	.section	.data.__strerror

;;
;;#define UNKNOWN_ERROR_ "unknown error "
;;static char _strerror_unknown_error[sizeof(UNKNOWN_ERROR_) + _strerror_max_length] = UNKNOWN_ERROR_;
;;static char* const _strerror_buffer = &_strerror_unknown_error[sizeof(UNKNOWN_ERROR_) - 1];
	.local	__strerror_unknown_error
__strerror_unknown_error:
	db	"unknown error "
	.local	__strerror_buffer
__strerror_buffer:
	ds	__strerror_max_length + 1


	.section	.text._strerror

;;
;;char* strerror(int errnum)
;;{
	.global	_strerror
	.type	_strerror, @function
_strerror:
	pop	de
	ex	(sp), hl
	push	de
	.global	_strerror.hijack_hl
	.type	_strerror.hijack_hl, @function
_strerror.hijack_hl:
	ex	de, hl
	.global	_strerror.hijack_de
	.type	_strerror.hijack_de, @function
_strerror.hijack_de:

;;  if (errnum >= 0 && errnum <= _strerror_max)
;;  {
	ld	hl, -(__strerror_max + 1)
	add	hl, de
	jr	c, .L.unknown_error

;;    if (!errnum) return (char*)_strerror_no_error;
	inc	e
	dec	e
	ld	hl, __strerror_no_error
	ret	z
;;
;;    const unsigned char* data = &_strerror_data_reversed[sizeof(_strerror_data_reversed)];
;;    char* dest;
;;
;;    for (unsigned char c = 1, b = errnum; b; --b)
;;    {
;;      dest = &_strerror_buffer[_strerror_max_length];
	ld	c, 1
	ld	b, e

.L.copy_next:
	ld	de, __strerror_buffer + __strerror_max_length
;;
;;      for (unsigned char a, first = true; true; first = false)
;;      {
;;        if (!first)
;;        {
	jr	.L.read_data_5b

;;          a -= 1 - 'A' + (a <= 'Z' - 'A' + 1 ? 0 : ('Z' + 1) - '0');
.L.decode_5b:
	sub	a, 'Z' - 'A' + 1 + 1
	sub	a, -('Z' + 1)
	jr	nc, .L.write_char
	sub	a, ('Z' + 1) - '0'

;;          *--dest = a;
.L.write_char:
	dec	de
	ld	(de), a

;;        }
;;
;;        a = -(1 << (8 - (5 - 1)));
;;        for (bool more = true; more;)
;;        {
.L.read_data_5b:
	ld	a, -(1 << (8 - (5 - 1)))

;;          bool read_data_byte = c == 1;
;;          if (read_data_byte)
;;          {
;;            c = *--data;
;;          }
;;          more = a >> 7;
;;          a = (a << 1) + (c & 1);
;;          c = (c >> 1) + (read_data_byte << 7);
;;        }
.L.read_data_bit:
	srl	c
	jr	nz, .L.no_read_data_byte
	dec	hl
	ld	c, (hl)
	rr	c
.L.no_read_data_byte:
	adc	a, a
	jr	c, .L.read_data_bit
;;
;;        if (!a) break;
;;      }
	jr	nz, .L.decode_5b

;;    }
	djnz	.L.copy_next
;;
;;    *--dest = 'E';
	ex	de, hl
	dec	hl
	ld	(hl), 'E'

;;    return dest;
	ret

;;  }
.L.unknown_error:
;;
;;  boot_sprintf(_strerror_buffer, "%d", errnum);
	push	de
	call	.L.format_d.end
	db	"%d", 0
.L.format_d.end:
	ld	hl, __strerror_buffer
	push	hl
	.extern	_boot_sprintf
	call	_boot_sprintf
	pop	hl
	pop	hl
	pop	hl

;;  return _strerror_unknown_error;
	ld	hl, __strerror_unknown_error
	ret

;;}
